database -open waves -into waves.shm -default
probe -create -shm tb_configure_cache.DUT.addr_i tb_configure_cache.DUT.aresetn_i tb_configure_cache.DUT.clk_i tb_configure_cache.DUT.empty_set tb_configure_cache.DUT.evict_way tb_configure_cache.DUT.hit tb_configure_cache.DUT.hit_o tb_configure_cache.DUT.miss_o tb_configure_cache.DUT.read_data tb_configure_cache.DUT.read_data_o tb_configure_cache.DUT.valid_o tb_configure_cache.DUT.valid_out tb_configure_cache.DUT.write_data_i tb_configure_cache.DUT.write_enable tb_configure_cache.DUT.write_enable_i tb_configure_cache.DUT.write_plru_enable tb_configure_cache.DUT.write_way
reset
run
exit
